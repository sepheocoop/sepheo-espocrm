{
    "links": {
        "cAvatar": {
            "type": "belongsTo",
            "entity": "Attachment",
            "skipOrmDefs": true,
            "utility": true
        },
        "assignedUsers": {
            "type": "hasMany",
            "entity": "User",
            "relationName": "entityUser",
            "layoutRelationshipsDisabled": true
        },
        "assignedUser": {
            "disabled": true
        },
        "cAttachment": {
            "type": "hasChildren",
            "entity": "Attachment",
            "foreign": "parent",
            "layoutRelationshipsDisabled": true,
            "relationName": "attachments",
            "utility": true
        },
        "cAttachments": {
            "type": "hasChildren",
            "entity": "Attachment",
            "foreign": "parent",
            "layoutRelationshipsDisabled": true,
            "relationName": "attachments",
            "utility": true
        }
    },
    "fields": {
        "cMembershipAspirations": {
            "type": "enum",
            "options": [
                "Affiliate",
                "Member"
            ],
            "style": {
                "Affiliate": null,
                "Member": null
            },
            "default": "Affiliate",
            "maxLength": 100,
            "isCustom": true,
            "labelType": "state",
            "tooltip": true
        },
        "cMatrixID": {
            "type": "varchar",
            "maxLength": 255,
            "options": [],
            "isCustom": true,
            "isPersonalData": true
        },
        "cWebsite": {
            "type": "urlMultiple",
            "storeArrayValues": true,
            "isCustom": true
        },
        "cAvatar": {
            "type": "image",
            "previewSize": "small",
            "isCustom": true
        },
        "cWorkCapacity": {
            "type": "enum",
            "required": true,
            "options": [
                "Some capacity",
                "No capacity",
                "Unengaged",
                ""
            ],
            "style": {
                "Some capacity": null,
                "No capacity": null,
                "Unengaged": null,
                "": null
            },
            "default": "Some capacity",
            "maxLength": 100,
            "isCustom": true
        },
        "cCvUrl": {
            "type": "urlMultiple",
            "storeArrayValues": true,
            "isCustom": true
        },
        "cAvailability": {
            "type": "enum",
            "options": [
                "Looking",
                "Not looking",
                ""
            ],
            "style": {
                "Looking": null,
                "Not looking": null,
                "": null
            },
            "default": "Looking",
            "maxLength": 100,
            "isCustom": true
        },
        "cOpenCollectiveID": {
            "type": "varchar",
            "maxLength": 100,
            "options": [],
            "isCustom": true,
            "isPersonalData": true
        },
        "cPhoneNumber": {
            "type": "varchar",
            "maxLength": 100,
            "isPersonalData": true,
            "options": [],
            "isCustom": true
        },
        "cJoinedAt": {
            "notNull": false,
            "type": "datetime",
            "minuteStep": 30,
            "isCustom": true
        },
        "lastName": {
            "required": false,
            "options": []
        },
        "assignedUsers": {
            "type": "linkMultiple",
            "view": "views/fields/assigned-users",
            "maxCount": 10
        },
        "assignedUser": {
            "disabled": true
        },
        "cOnboardings": {
            "type": "multiEnum",
            "storeArrayValues": true,
            "default": [],
            "options": [
                "Affiliate",
                "Member",
                "Steward"
            ],
            "style": {
                "Affiliate": null,
                "Member": null,
                "Steward": null
            },
            "displayAsLabel": true,
            "labelType": "state",
            "audited": true,
            "tooltip": true,
            "isCustom": true
        },
        "cAttachment": {
            "type": "attachmentMultiple",
            "previewSize": "medium",
            "sourceList": [
                "Document"
            ],
            "accept": [
                ".pdf",
                ".doc",
                ".pptx",
                ".md",
                ".txt"
            ],
            "isCustom": true,
            "isPersonalData": true,
            "maxCount": 1,
            "maxFileSize": 1
        },
        "cAttachments": {
            "type": "attachmentMultiple",
            "previewSize": "medium",
            "isPersonalData": true,
            "sourceList": [],
            "accept": [],
            "tooltip": true,
            "isCustom": true
        },
        "cAbout": {
            "type": "text",
            "rowsMin": 2,
            "cutHeight": 200,
            "isCustom": true
        },
        "cNeeds": {
            "type": "text",
            "rowsMin": 2,
            "cutHeight": 200,
            "isCustom": true
        },
        "cOffers": {
            "type": "text",
            "rowsMin": 2,
            "cutHeight": 200,
            "isCustom": true
        },
        "cProvenance": {
            "type": "text",
            "rowsMin": 2,
            "cutHeight": 200,
            "isCustom": true
        },
        "cConnections": {
            "type": "text",
            "rowsMin": 2,
            "cutHeight": 200,
            "isCustom": true
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc",
        "textFilterFields": [
            "name",
            "emailAddress",
            "description",
            "addressCity",
            "addressState"
        ],
        "fullTextSearch": true,
        "countDisabled": false
    },
    "optimisticConcurrencyControl": false
}