{
  "name": "espocrm-ext-contact-portal",
  "version": "0.0.1",
  "description": "",
  "scripts": {
    "sa": "vendor/bin/phpstan",
    "unit-tests": "vendor/bin/phpunit",
    "integration-tests": "node build --copy && node build --composer-install && cd site && php vendor/bin/phpunit tests/integration/Espo/Modules/ContactPortal",
    "copy": "node build --copy",
    "composer-install": "node build --composer-install",
    "docker-copy": "node docker-copy.js",
    "sync": "node build --copy && node build --composer-install && node docker-copy.js",
    "extension": "node build --extension",
    "clear-cache": "php site/clear_cache.php",
    "rebuild": "node build --rebuild",
    "all": "node build --all",
    "prepare-test": "node build --prepare-test"
  },
  "type": "module",
  "author": "Sepheo",
  "dependencies": {
    "espo-extension-tools": "github:espocrm/extension-tools#0.3.6",
